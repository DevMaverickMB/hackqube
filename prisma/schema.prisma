generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  clerkId   String   @unique @map("clerk_id")
  name      String
  email     String   @unique
  role      Role     @default(participant)
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  presentations   Presentation[]
  votes           Vote[]
  openedSessions  VotingSession[] @relation("SessionOpener")
  auditLogs       AuditLog[]
  sharedArticles  SharedArticle[]

  @@map("users")
}

model Presentation {
  id                   String               @id @default(uuid()) @db.Uuid
  userId               String               @map("user_id") @db.Uuid
  scheduledDate        DateTime?            @map("scheduled_date") @db.Date
  title                String?
  problemStatement     String?              @map("problem_statement")
  aiToolsUsed          String[]             @map("ai_tools_used")
  approach             String?
  demoLink             String?              @map("demo_link")
  impactLevel          ImpactLevel?         @map("impact_level")
  category             FunctionalCategory?
  status               PresentationStatus   @default(upcoming)
  implementationStatus ImplementationStatus @default(proposed) @map("implementation_status")
  attachments          String[]             @default([])
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user           User            @relation(fields: [userId], references: [id])
  votes          Vote[]
  score          Score?
  votingSessions VotingSession[]

  @@map("presentations")
}

model Vote {
  id                String   @id @default(uuid()) @db.Uuid
  voterId           String   @map("voter_id") @db.Uuid
  presentationId    String   @map("presentation_id") @db.Uuid
  ideaScore         Int      @map("idea_score") @db.SmallInt
  executionScore    Int      @map("execution_score") @db.SmallInt
  helpfulnessScore  Int      @map("helpfulness_score") @db.SmallInt
  presentationScore Int      @map("presentation_score") @db.SmallInt
  submittedAt       DateTime @default(now()) @map("submitted_at") @db.Timestamptz

  voter        User         @relation(fields: [voterId], references: [id])
  presentation Presentation @relation(fields: [presentationId], references: [id])

  @@unique([voterId, presentationId])
  @@map("votes")
}

model Score {
  id              String   @id @default(uuid()) @db.Uuid
  presentationId  String   @unique @map("presentation_id") @db.Uuid
  avgIdea         Decimal  @default(0) @map("avg_idea") @db.Decimal(3, 2)
  avgExecution    Decimal  @default(0) @map("avg_execution") @db.Decimal(3, 2)
  avgHelpfulness  Decimal  @default(0) @map("avg_helpfulness") @db.Decimal(3, 2)
  avgPresentation Decimal  @default(0) @map("avg_presentation") @db.Decimal(3, 2)
  finalScore      Decimal  @default(0) @map("final_score") @db.Decimal(3, 2)
  voteCount       Int      @default(0) @map("vote_count")
  computedAt      DateTime @default(now()) @map("computed_at") @db.Timestamptz

  presentation Presentation @relation(fields: [presentationId], references: [id])

  @@map("scores")
}

model VotingSession {
  id             String    @id @default(uuid()) @db.Uuid
  presentationId String    @map("presentation_id") @db.Uuid
  openedAt       DateTime? @map("opened_at") @db.Timestamptz
  closesAt       DateTime? @map("closes_at") @db.Timestamptz
  closedAt       DateTime? @map("closed_at") @db.Timestamptz
  openedBy       String    @map("opened_by") @db.Uuid
  isActive       Boolean   @default(false) @map("is_active")

  presentation Presentation @relation(fields: [presentationId], references: [id])
  opener       User         @relation("SessionOpener", fields: [openedBy], references: [id])

  @@map("voting_sessions")
}

model SharedArticle {
  id          String        @id @default(uuid()) @db.Uuid
  url         String
  title       String
  description String?
  imageUrl    String?       @map("image_url")
  source      ArticleSource @default(user)
  sourceName  String?       @map("source_name")
  sharedById  String?       @map("shared_by_id") @db.Uuid
  pinnedAt    DateTime?     @map("pinned_at") @db.Timestamptz
  pinnedUntil DateTime?     @map("pinned_until") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  sharedBy User? @relation(fields: [sharedById], references: [id])

  @@map("shared_articles")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id") @db.Uuid
  beforeVal  Json?    @map("before_val")
  afterVal   Json?    @map("after_val")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

enum Role {
  admin
  participant
}

enum ArticleSource {
  user
  rss
  newsapi
}

enum ImpactLevel {
  low
  medium
  high
  critical
}

enum FunctionalCategory {
  ops
  product
  sales
  support
  engineering
  other
}

enum PresentationStatus {
  upcoming
  completed
  cancelled
}

enum ImplementationStatus {
  proposed
  under_review
  in_progress
  implemented
  rejected
}
